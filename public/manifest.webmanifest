{
  "name": "Shogi App",
  "short_name": "Shogi",
  "description": "A minimal local shogi app with promotion, drops, check, and checkmate.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#f6efe1",
  "theme_color": "#2f6f58",
  "icons": [
    {
      "src": "/icons/icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ]
}
